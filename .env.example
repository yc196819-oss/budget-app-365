# AI provider
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Secondary AI provider (fallback when Gemini fails)
GROK_API_KEY=
GROK_MODEL=grok-2-latest
# Optional custom base URL if needed
GROK_BASE_URL=https://api.x.ai/v1

# Supabase server access (for reset code + secure data reset)
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# App URL used in reset emails
APP_URL=http://127.0.0.1:5500/budget-final%20(2).html

# Google OAuth for per-user Gmail sending
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8787/api/google/callback
# Optional (comma-separated); default already includes gmail.send
GOOGLE_OAUTH_SCOPES=openid,email,https://www.googleapis.com/auth/gmail.send

# Preferred mail sender: HTTPS API, works even where outbound SMTP ports
# are blocked (e.g. Render's free tier). Tried first if set.
# Sign up at https://resend.com, create an API key.
RESEND_API_KEY=
# resend.dev works with no domain verification; switch once a custom
# domain is verified on the Resend account.
RESEND_FROM="Budget App <onboarding@resend.dev>"

# SMTP settings for sending reset code emails and reminder tests
# (fallback if RESEND_API_KEY isn't set -- may hang/fail on hosts that
# block outbound SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Budget App <no-reply@yourdomain.com>"

# Local API server port
PORT=8787
